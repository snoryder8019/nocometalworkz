<div id="cartDiv" class="cart">
    <div class="eventBody">
        <h1>Cart Details</h1>
<div class="cartContain">
   
    <% if (typeof user == 'object' && user) { %>
    <div><h2><%= user.firstName%></h2>
   <br> <h2><%= user.email%></h2>
   <br> <h2><%= user%></h2></div>
   
    <% if(typeof user.cart == 'array' && user.cart){%>
    <div>cart items: </div>

    <div>total</div>
    <%- include('paypal.ejs')%>
    <%}else{%>
        <h2>no cart items</h2>
        <%}%>
     <%}else{%>
        <h2>sign in to use this feature</h2>
      
    <%}%>
    
  
</div>

<button onclick="shrinkCart()"><h2>shrink cart</h2></button>

</div>
</div>