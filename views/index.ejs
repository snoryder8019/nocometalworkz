<!DOCTYPE html>
<html>

    <%- include('config/head.ejs')%>

<body onload="bodyLoader()">
    <%- include('partials/cart.ejs')%>
    <canvas id="bkgdCanvas"></canvas>  
   
    <div id="backgroundFX">
 <div id="mainBody" class="mainStyle">
 
    <%- include('config/bkgdImg.ejs')%>
    <%- include('config/header.ejs')%>
    <%- include('config/intro.ejs')%>
 
    <div class="eventBody">
        <h1 class="h1Span">Our Newest Workz!</h1>
        <div class="invGrid">
            <% for(var i=0;i<data.length;i++){%>
                <div class="gridContain">
                    <a href="/productID/<%= data[i]._id%>">
                        <div>
                            <span class="background-image" role="img" aria-label="<%=data[i].details%>"> </span>
                         
                            </div>
                        <div style="background-image: url('<%= data[i].imgName%>');" class="invBox"> </div></a>
                    
                </div>
                <%}%>
            </div>
        </div>
        
        <%= locals.hellos%>
        
        <div class="midBar">
            <div class="midLeft">
                <div class="landingPage0">
            <a href="/market">     <div class="navBox">
                marketplace
            </div></a>
        </div>
<div class="landingPage0">
   <a href="/about"> <div class="navBox">
        about
    </div></a>
</div>
<div class="landingPage0">
    <a href="/faqs">   <div class="navBox">
        F.A.Q.s
    </div></a>
</div>
</div>
<div class="midRight">
    <%- include('config/icons/icon_set.ejs')%>

</div>




</div>

<h1 class="h1Span">Our Recent Events and Posts</h1>
<div class="landingPage">   
    <% for(var i=0;i<blogs.length;i++){%>
        <div class="eventBody">
                    <h1><%= blogs[i].bTitle%></h1>
                    <h2><%= blogs[i].bSubtitle%></h2>
                    <p><%= blogs[i].bDetails%></p>
                    <div style="background-image:url('<%= blogs[i].imgName%>');" class="imgBox"></div>
                </div>
                    <%}%>
        </div>

      <%- include('config/footer.ejs')%>

    </div>
</div>

<%- include('./config/baseScripts.ejs')%>
</body>
 </html>